# =============================
# Homesurge (Vite) Environment
# =============================
# Copy this file to .env and fill in values.

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: AI listing blurbs (legacy; now served via /api/ai proxy)
# If blank, frontend still works; AI features require server-side keys (see Vercel env vars below).
VITE_GEMINI_API_KEY=

# Optional: direct AI keys for local dev fallback (used by vite only)
VITE_GROQ_API_KEY=
VITE_MOONDREAM_API_KEY=
VITE_TAVILY_API_KEY=

# Customer-facing bureau line shown on listings
VITE_HOMESURGE_PUBLIC_PHONE=

# Optional WhatsApp deeplink
VITE_HOMESURGE_WHATSAPP_URL=

# =====================================================
# Server-side AI keys (Vercel /api/ai.ts)
# These are NOT exposed to the browser. Set them in Vercel
# project settings or in a local .env file (do NOT commit).
# =====================================================
# GROQ_API_KEY=          # Free, fast chat for admin assistant + customer chatbot
# GEMINI_API_KEY=        # Fallback LLM for chat, translation, deal analysis, parsing
# MOONDREAM_API_KEY=     # Vision AI for image quality checks
# TAVILY_API_KEY=        # Web search for area insights (optional)
# OPENROUTER_API_KEY=    # Fallback router (optional)
# MISTRAL_API_KEY=       # Fallback LLM (optional)
# DEEPSEEK_API_KEY=      # Fallback LLM (optional)
# ELEVENLABS_API_KEY=    # Voice (planned, optional)
